# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to git

# Firebase Admin SDK (from Firebase Console > Project Settings > Service Accounts)
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"

# PerfectMind API (Burlington-specific — do not change)
PERFECTMIND_CALENDAR_ID=517e0420-1478-458e-8a6f-ad813e278ec0
PERFECTMIND_WIDGET_ID=a5b21c07-15df-4aee-9505-42bd58803cdf
